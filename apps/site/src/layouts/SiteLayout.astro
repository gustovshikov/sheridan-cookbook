---
interface RecipeNavItem {
  id: string;
  title: string;
  category: string;
  folderPath?: string[];
  sourcePath: string;
  url: string;
}

interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  recipes?: RecipeNavItem[];
  currentRecipeId?: string;
  currentPage?: 'home' | 'about' | 'add' | 'sources';
  toc?: TocItem[];
}

const {
  title,
  description = 'A Markdown-powered Sheridan family recipe collection.',
  recipes = [],
  currentRecipeId,
  currentPage,
  toc = [],
} = Astro.props;

const categories = [...new Set(recipes.map((recipe) => recipe.category))].sort();
const recipesByCategory = categories.map((category) => ({
  category,
  id: category.toLowerCase(),
  recipes: recipes
    .filter((recipe) => recipe.category === category)
    .sort((a, b) => a.title.localeCompare(b.title)),
}));
const mobileTocLabel = toc.length > 0 ? 'Overview' : 'No sections';

const groupRecipesByFolder = (recipes: RecipeNavItem[]) => {
  const directRecipes: RecipeNavItem[] = [];
  const folderMap = new Map<string, { label: string; recipes: RecipeNavItem[] }>();

  for (const recipe of recipes) {
    const folderPath = recipe.folderPath ?? [];

    if (folderPath.length === 0) {
      directRecipes.push(recipe);
      continue;
    }

    const key = folderPath.join('/');
    const label = folderPath.join(' / ');
    const group = folderMap.get(key) ?? { label, recipes: [] };

    group.recipes.push(recipe);
    folderMap.set(key, group);
  }

  return {
    directRecipes,
    folderGroups: [...folderMap.values()].sort((a, b) => a.label.localeCompare(b.label)),
  };
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      (() => {
        const storageKey = 'recipe-theme';
        const validThemes = ['light', 'dark', 'auto'];
        let savedTheme;
        try {
          savedTheme = localStorage.getItem(storageKey);
        } catch {
          savedTheme = null;
        }
        const theme = validThemes.includes(savedTheme) ? savedTheme : 'auto';
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const colorScheme = theme === 'auto' ? (systemDark ? 'dark' : 'light') : theme;

        document.documentElement.dataset.theme = theme;
        document.documentElement.dataset.colorScheme = colorScheme;
        document.documentElement.style.colorScheme = colorScheme;
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>
          <strong>Sheridan Family Cookbook</strong>
          <small>cookbook.cyberhelm.com</small>
        </span>
      </a>
      <div class="header-search-row">
        <div class="header-search">
          <label for="recipe-search">Search recipes</label>
          <input id="recipe-search" type="search" placeholder="Search recipes..." data-recipe-search />
          <div class="search-results" data-search-results aria-live="polite"></div>
        </div>
        <a
          class:list={['header-add-link', { active: currentPage === 'add' }]}
          href="/add-recipe/"
        >
          Submit Recipe
        </a>
      </div>
      <div class="header-actions">
        <label class="theme-select">
          <span>Theme</span>
          <select data-theme-select aria-label="Color theme">
            <option value="light">Light</option>
            <option value="dark">Dark</option>
            <option value="auto">Auto</option>
          </select>
        </label>
        <button
          class="search-toggle"
          type="button"
          aria-label="Open search"
          aria-controls="recipe-search"
          aria-expanded="false"
          data-search-toggle
        ></button>
        <button
          class="menu-toggle"
          type="button"
          aria-label="Open menu"
          aria-controls="recipe-menu"
          aria-expanded="false"
          data-menu-toggle
        >
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
      </div>
    </header>

    <div class="mobile-menu-backdrop" data-menu-backdrop></div>

    <div class="app-shell">
      <aside class="left-rail" id="recipe-menu" aria-label="Recipes" data-mobile-menu>
        <nav class="site-nav" aria-label="Site pages">
          <a
            class:list={['site-nav-link', { active: currentPage === 'home' }]}
            href="/"
            aria-current={currentPage === 'home' ? 'page' : undefined}
          >
            Home
          </a>
          <a
            class:list={['site-nav-link', { active: currentPage === 'about' }]}
            href="/about/"
            aria-current={currentPage === 'about' ? 'page' : undefined}
          >
            About
          </a>
          <a
            class:list={['site-nav-link', { active: currentPage === 'sources' }]}
            href="/family-sources/"
            aria-current={currentPage === 'sources' ? 'page' : undefined}
          >
            Family Sources
          </a>
        </nav>
        <nav class="recipe-nav" aria-label="Recipe list">
          {
            recipesByCategory.map(({ category, recipes }) => {
              const isOpen = recipes.some((recipe) => recipe.id === currentRecipeId);
              const { directRecipes, folderGroups } = groupRecipesByFolder(recipes);

              return (
                <details class="nav-group" open={isOpen}>
                  <summary>
                    <span>{category}</span>
                  </summary>
                  <ul>
                    {directRecipes.map((recipe) => (
                      <li>
                        <a
                          class:list={['recipe-nav-link', { active: recipe.id === currentRecipeId }]}
                          href={recipe.url}
                          aria-current={recipe.id === currentRecipeId ? 'page' : undefined}
                        >
                          {recipe.title}
                        </a>
                      </li>
                    ))}
                    {folderGroups.map((group) => {
                      const isFolderOpen =
                        group.recipes.some((recipe) => recipe.id === currentRecipeId);

                      return (
                        <li>
                          <details class="nav-subgroup" open={isFolderOpen}>
                            <summary>
                              <span>{group.label}</span>
                            </summary>
                            <ul>
                              {group.recipes.map((recipe) => (
                                <li>
                                  <a
                                    class:list={[
                                      'recipe-nav-link',
                                      { active: recipe.id === currentRecipeId },
                                    ]}
                                    href={recipe.url}
                                    aria-current={
                                      recipe.id === currentRecipeId ? 'page' : undefined
                                    }
                                  >
                                    {recipe.title}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          </details>
                        </li>
                      );
                    })}
                  </ul>
                </details>
              );
            })
          }
        </nav>
        <div class="mobile-menu-tools">
          <label class="theme-select mobile-theme-select">
            <span>Theme</span>
            <select data-theme-select aria-label="Color theme">
              <option value="light">Light</option>
              <option value="dark">Dark</option>
              <option value="auto">Auto</option>
            </select>
          </label>
        </div>
      </aside>

      <main id="_top">
        <slot />
      </main>

      <aside class="right-rail" aria-label="On this page">
        <div class="toc-panel">
          <h2 class="toc-heading">On This Page</h2>
          {
            toc.length > 0 ? (
              <>
                <details class="mobile-toc" data-mobile-toc>
                  <summary>
                    <span>On this page</span>
                    <strong data-toc-current>{mobileTocLabel}</strong>
                  </summary>
                  <nav aria-label="Page sections">
                    <ul>
                      <li>
                        <a href="#_top">Overview</a>
                      </li>
                      {toc.map((item) => (
                        <li class={`toc-depth-${Math.min(Math.max(item.depth, 2), 4)}`}>
                          <a href={`#${item.slug}`}>{item.text}</a>
                        </li>
                      ))}
                    </ul>
                  </nav>
                </details>
                <nav class="desktop-toc" aria-label="Page sections">
                  <ul>
                    {toc.map((item) => (
                      <li class={`toc-depth-${Math.min(Math.max(item.depth, 2), 4)}`}>
                        <a href={`#${item.slug}`}>{item.text}</a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </>
            ) : (
              <p>Select a recipe to see its sections.</p>
            )
          }
        </div>
      </aside>
    </div>

    <script>
      const themeStorageKey = 'recipe-theme';
      const themeSelects = Array.from(document.querySelectorAll('[data-theme-select]'));
      const systemTheme = window.matchMedia('(prefers-color-scheme: dark)');

      const getThemeMode = () => {
        try {
          const savedTheme = localStorage.getItem(themeStorageKey);
          return ['light', 'dark', 'auto'].includes(savedTheme) ? savedTheme : 'auto';
        } catch {
          return 'auto';
        }
      };

      const saveThemeMode = (theme) => {
        try {
          localStorage.setItem(themeStorageKey, theme);
        } catch {
          // Ignore storage failures; the current page can still switch themes.
        }
      };

      const getColorScheme = (theme) =>
        theme === 'auto' ? (systemTheme.matches ? 'dark' : 'light') : theme;

      const applyTheme = (theme) => {
        const colorScheme = getColorScheme(theme);

        document.documentElement.dataset.theme = theme;
        document.documentElement.dataset.colorScheme = colorScheme;
        document.documentElement.style.colorScheme = colorScheme;

        themeSelects.forEach((select) => {
          if (select instanceof HTMLSelectElement) select.value = theme;
        });
      };

      themeSelects.forEach((select) => {
        if (!(select instanceof HTMLSelectElement)) return;

        select.addEventListener('change', () => {
          const theme = select.value;
          saveThemeMode(theme);
          applyTheme(theme);
        });
      });

      const handleSystemThemeChange = () => {
        if (getThemeMode() === 'auto') applyTheme('auto');
      };

      if (systemTheme.addEventListener) {
        systemTheme.addEventListener('change', handleSystemThemeChange);
      } else {
        systemTheme.addListener(handleSystemThemeChange);
      }

      applyTheme(getThemeMode());

      const mobileMenu = document.querySelector('[data-mobile-menu]');
      const menuToggle = document.querySelector('[data-menu-toggle]');
      const menuBackdrop = document.querySelector('[data-menu-backdrop]');
      const mobileMenuQuery = window.matchMedia('(max-width: 1080px)');

      const setMenuOpen = (isOpen) => {
        document.body.dataset.menuOpen = String(isOpen);
        menuToggle?.setAttribute('aria-expanded', String(isOpen));
        menuToggle?.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
      };

      const closeMenu = () => setMenuOpen(false);

      menuBackdrop?.addEventListener('click', closeMenu);

      mobileMenu?.addEventListener('click', (event) => {
        const link = event.target instanceof Element ? event.target.closest('a') : null;
        if (link && mobileMenuQuery.matches) {
          closeMenu();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMenu();
      });

      const handleMenuBreakpointChange = () => {
        if (!mobileMenuQuery.matches) closeMenu();
      };

      if (mobileMenuQuery.addEventListener) {
        mobileMenuQuery.addEventListener('change', handleMenuBreakpointChange);
      } else {
        mobileMenuQuery.addListener(handleMenuBreakpointChange);
      }

      const input = document.querySelector('[data-recipe-search]');
      const results = document.querySelector('[data-search-results]');
      const searchToggle = document.querySelector('[data-search-toggle]');

      const setSearchOpen = (isOpen) => {
        document.body.dataset.searchOpen = String(isOpen);
        searchToggle?.setAttribute('aria-expanded', String(isOpen));
        searchToggle?.setAttribute('aria-label', isOpen ? 'Close search' : 'Open search');

        if (isOpen && input instanceof HTMLInputElement) input.focus();
      };

      menuToggle?.addEventListener('click', () => {
        const isOpen = document.body.dataset.menuOpen === 'true';
        if (!isOpen) setSearchOpen(false);
        setMenuOpen(!isOpen);
      });

      const normalize = (value) => value.toLowerCase().trim();
      const escapeHtml = (value) =>
        value.replace(
          /[&<>"']/g,
          (character) =>
            ({
              '&': '&amp;',
              '<': '&lt;',
              '>': '&gt;',
              '"': '&quot;',
              "'": '&#39;',
            })[character],
        );
      let searchIndex = [];

      const renderResults = (matches, query) => {
        if (!results) return;

        if (!query) {
          results.innerHTML = '';
          return;
        }

        if (matches.length === 0) {
          results.innerHTML = '<p>No recipes found.</p>';
          return;
        }

        results.innerHTML = matches
          .slice(0, 8)
          .map((recipe) => {
            const detail = [
              recipe.category,
              recipe.source ? `Source: ${recipe.source}` : '',
              Array.isArray(recipe.tags) ? recipe.tags.slice(0, 3).join(', ') : '',
            ]
              .filter(Boolean)
              .join(' · ');

            return `
              <a href="${recipe.url}">
                <strong>${escapeHtml(recipe.title)}</strong>
                <span>${escapeHtml(detail)}</span>
              </a>
            `;
          })
          .join('');
      };

      const runSearch = () => {
        if (!input) return;

        const query = normalize(input.value);
        const terms = query.split(/\s+/).filter(Boolean);
        const matches = searchIndex.filter((recipe) =>
          terms.every((term) => recipe.searchText.includes(term)),
        );

        renderResults(matches, query);
      };

      fetch('/search.json')
        .then((response) => response.json())
        .then((recipes) => {
          searchIndex = recipes.map((recipe) => ({
            ...recipe,
            searchText: normalize(
              [
                recipe.title,
                recipe.category,
                recipe.source,
                recipe.status,
                recipe.servings,
                recipe.prepTime,
                recipe.cookTime,
                recipe.temperature,
                recipe.sourcePath,
                Array.isArray(recipe.tags) ? recipe.tags.join(' ') : '',
                recipe.content,
              ]
                .filter(Boolean)
                .join(' '),
            ),
          }));
        })
        .catch(() => {
          if (results) results.innerHTML = '<p>Search index unavailable.</p>';
        });

      input?.addEventListener('input', runSearch);
      input?.addEventListener('focus', runSearch);

      const closeSearch = () => {
        if (results) results.innerHTML = '';
        setSearchOpen(false);
      };

      searchToggle?.addEventListener('click', () => {
        const isOpen = document.body.dataset.searchOpen === 'true';
        setSearchOpen(!isOpen);
        if (!isOpen) runSearch();
      });

      results?.addEventListener('click', (event) => {
        const link = event.target instanceof Element ? event.target.closest('a') : null;
        if (link && mobileMenuQuery.matches) {
          closeMenu();
          closeSearch();
        }
      });

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (!target) return;
        if (target.closest('.header-search') || target.closest('[data-search-toggle]')) return;

        closeSearch();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeSearch();
      });

      const mobileToc = document.querySelector('[data-mobile-toc]');
      const tocCurrent = document.querySelector('[data-toc-current]');
      const tocLinks = Array.from(document.querySelectorAll('.mobile-toc a[href^="#"]'));

      const updateTocCurrent = () => {
        if (!tocCurrent) return;

        let current = 'Overview';

        for (const link of tocLinks) {
          const hash = link.getAttribute('href');
          if (!hash || hash === '#_top') continue;

          const section = document.querySelector(hash);
          if (section && section.getBoundingClientRect().top <= 140) {
            current = link.textContent.trim();
          }
        }

        tocCurrent.textContent = current;
      };

      tocLinks.forEach((link) => {
        link.addEventListener('click', () => {
          if (mobileToc instanceof HTMLDetailsElement && mobileMenuQuery.matches) {
            mobileToc.open = false;
          }
        });
      });

      document.addEventListener('click', (event) => {
        if (!(mobileToc instanceof HTMLDetailsElement)) return;
        if (!mobileMenuQuery.matches || !mobileToc.open) return;

        const target = event.target instanceof Element ? event.target : null;
        if (!target || target.closest('[data-mobile-toc]')) return;

        mobileToc.open = false;
      });

      document.addEventListener('scroll', updateTocCurrent, { passive: true });
      window.addEventListener('resize', updateTocCurrent);
      updateTocCurrent();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #faf8f2;
    --ink: #25231f;
    --muted: #686157;
    --line: #ded6c8;
    --paper: #fffdf8;
    --paper-strong: #f1eadb;
    --panel: rgba(255, 253, 248, 0.82);
    --header-bg: rgba(250, 248, 242, 0.94);
    --grid-line: rgba(37, 35, 31, 0.035);
    --focus-ring: rgba(52, 120, 108, 0.24);
    --nav-hover: rgba(52, 120, 108, 0.08);
    --accent: #34786c;
    --accent-strong: #24564e;
    --ember: #b44a2c;
    --gold: #c18b2d;
    --shadow: 0 12px 30px rgba(37, 35, 31, 0.08);
    --brand-mark-border: #c4a46a;
    --brand-mark-bg:
      linear-gradient(135deg, rgba(196, 164, 106, 0.7), rgba(255, 253, 248, 0.1)),
      repeating-linear-gradient(45deg, rgba(52, 120, 108, 0.28) 0 4px, transparent 4px 8px);
    --card-art-bg:
      linear-gradient(135deg, rgba(180, 74, 44, 0.22), transparent 50%),
      linear-gradient(45deg, rgba(52, 120, 108, 0.2), transparent 55%),
      repeating-linear-gradient(90deg, rgba(193, 139, 45, 0.32) 0 8px, transparent 8px 16px),
      #f7f0e2;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      "Helvetica Neue", "Noto Sans", Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji",
      "Segoe UI Symbol", "Noto Color Emoji";
  }

  :root[data-color-scheme='dark'] {
    --bg: #171512;
    --ink: #f3eee5;
    --muted: #b8aa99;
    --line: #40372e;
    --paper: #211d19;
    --paper-strong: #2b251f;
    --panel: rgba(33, 29, 25, 0.84);
    --header-bg: rgba(23, 21, 18, 0.94);
    --grid-line: rgba(243, 238, 229, 0.045);
    --focus-ring: rgba(88, 166, 150, 0.28);
    --nav-hover: rgba(88, 166, 150, 0.14);
    --accent: #58a696;
    --accent-strong: #9dd8cc;
    --ember: #e47d61;
    --gold: #d6aa52;
    --shadow: 0 16px 34px rgba(0, 0, 0, 0.28);
    --brand-mark-border: #7d6745;
    --brand-mark-bg:
      linear-gradient(135deg, rgba(214, 170, 82, 0.34), rgba(33, 29, 25, 0.2)),
      repeating-linear-gradient(45deg, rgba(88, 166, 150, 0.22) 0 4px, transparent 4px 8px);
    --card-art-bg:
      linear-gradient(135deg, rgba(228, 125, 97, 0.18), transparent 50%),
      linear-gradient(45deg, rgba(88, 166, 150, 0.2), transparent 55%),
      repeating-linear-gradient(90deg, rgba(214, 170, 82, 0.2) 0 8px, transparent 8px 16px),
      #2f2820;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-padding-top: 6rem;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.6;
  }

  body[data-menu-open='true'] {
    overflow: hidden;
  }

  a {
    color: var(--accent-strong);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(12rem, 1fr) minmax(16rem, 36rem) minmax(7rem, 1fr);
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.25rem);
    min-height: 3.5rem;
    padding: 0.5rem clamp(1rem, 4vw, 2rem);
    border-bottom: 1px solid var(--line);
    background: var(--header-bg);
    backdrop-filter: blur(12px);
  }

  .menu-toggle,
  .search-toggle {
    display: none;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid var(--line);
    border-radius: 0.45rem;
    background: var(--paper);
    color: var(--ink);
    cursor: pointer;
    padding: 0;
  }

  .search-toggle {
    position: relative;
  }

  .search-toggle::before,
  .search-toggle::after {
    display: block;
    grid-area: 1 / 1;
    content: '';
  }

  .search-toggle::before {
    width: 0.95rem;
    height: 0.95rem;
    border: 2px solid currentColor;
    border-radius: 999px;
  }

  .search-toggle::after {
    width: 0.55rem;
    height: 2px;
    background: currentColor;
    transform: translate(0.45rem, 0.45rem) rotate(45deg);
  }

  .menu-toggle:hover,
  .menu-toggle:focus-visible,
  .search-toggle:hover,
  .search-toggle:focus-visible {
    border-color: var(--accent);
    background: var(--nav-hover);
    outline: 2px solid var(--focus-ring);
  }

  .menu-toggle span {
    display: block;
    grid-area: 1 / 1;
    width: 1.15rem;
    height: 2px;
    background: currentColor;
    transition:
      transform 160ms ease,
      opacity 160ms ease;
  }

  .menu-toggle span:nth-child(1) {
    transform: translateY(-0.38rem);
  }

  .menu-toggle span:nth-child(3) {
    transform: translateY(0.38rem);
  }

  body[data-menu-open='true'] .menu-toggle span:nth-child(1) {
    transform: rotate(45deg);
  }

  body[data-menu-open='true'] .menu-toggle span:nth-child(2) {
    opacity: 0;
  }

  body[data-menu-open='true'] .menu-toggle span:nth-child(3) {
    transform: rotate(-45deg);
  }

  .mobile-menu-backdrop {
    position: fixed;
    inset: 0;
    z-index: 20;
    background: rgba(0, 0, 0, 0.36);
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms ease;
  }

  body[data-menu-open='true'] .mobile-menu-backdrop {
    opacity: 1;
    pointer-events: auto;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    color: var(--ink);
    text-decoration: none;
  }

  .brand-mark {
    display: none;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 1rem;
    line-height: 1.2;
  }

  .brand small {
    display: none;
  }

  .header-actions {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0.5rem;
    justify-self: end;
    justify-content: flex-end;
  }

  .header-search-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .header-search {
    position: relative;
    min-width: 0;
  }

  .header-search label,
  .theme-select span {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .header-search input {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 0.45rem;
    background: var(--paper);
    color: var(--ink);
    font: inherit;
    font-size: 0.95rem;
    padding: 0.46rem 0.7rem;
  }

