---
import { getCollection, render } from 'astro:content';
import SourceLinks from '../../components/SourceLinks.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');

  return recipes.map((recipe) => ({
    params: { id: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const allRecipes = (await getCollection('recipes')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
const navRecipes = allRecipes.map((recipe) => ({
  id: recipe.id,
  title: recipe.data.title,
  category: recipe.data.category,
  folderPath: recipe.data.folderPath,
  sourcePath: recipe.data.sourcePath,
  url: `/recipes/${recipe.id}/`,
}));
const { Content, headings } = await render(recipe);
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 4);
const recipeFacts = [
  ['Category', recipe.data.category],
  ['Servings', recipe.data.servings],
  ['Prep', recipe.data.prepTime],
  ['Cook', recipe.data.cookTime],
  ['Temp', recipe.data.temperature],
].filter(([, value]) => Boolean(value));
---

<SiteLayout
  title={`${recipe.data.title} | Sheridan Family Cookbook`}
  recipes={navRecipes}
  currentRecipeId={recipe.id}
  toc={toc}
>
  <div class="recipe-page">
    <article class="recipe-article">
      <h1>{recipe.data.title}</h1>
      <p class="recipe-meta">{recipe.data.sourcePath}</p>
      <ul class="recipe-facts" aria-label="Recipe details">
        {
          recipe.data.source && (
            <li>
              <strong>Source:</strong> <SourceLinks source={recipe.data.source} />
            </li>
          )
        }
        {recipeFacts.map(([label, value]) => (
          <li>
            <strong>{label}:</strong> {value}
          </li>
        ))}
      </ul>
      {
        recipe.data.tags.length > 0 && (
          <ul class="tag-list recipe-tags" aria-label="Recipe tags">
            {recipe.data.tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      }
      <Content />
    </article>
  </div>
</SiteLayout>
